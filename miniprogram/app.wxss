/* ===== 字体系统 ===== */

page {
  --green-deep: #1a5c4f;
  --green: #1d6f5f;
  --green-light: #248b76;
  --green-ghost: #edf7f2;
  --bg: #f3f6f5;
  --bg-explore: #f0f2f0;
  --white: #ffffff;
  --card-bg: #ffffff;
  --text: #1d2b27;
  --text-soft: #4a5c56;
  --text-muted: #7a8a85;
  --border: #dde6e2;
  --border-soft: #eaf0ed;
  --red-soft: #ffecec;
  --red: #d94848;
  --orange-soft: #fff3e6;
  --orange: #d86b2b;
  --blue-soft: #eaf3ff;
  --blue: #3d7fd4;

  background: var(--bg);
  color: var(--text);
  font-family:
    "PingFang SC",
    "Hiragino Sans GB",
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    "Helvetica Neue",
    sans-serif;
  -webkit-font-smoothing: antialiased;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ===== 字号层级 ===== */

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0;
  margin: 0 0 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-muted);
  line-height: 1.5;
  margin: 0 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
  margin: 0 0 16rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
  word-break: break-word;
}

.muted {
  color: var(--text-muted);
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.5;
}

.mini {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--text-soft);
  line-height: 1.4;
}

.page-hero {
  margin-bottom: 32rpx;
}

/* ===== 卡片系统 ===== */

.card {
  position: relative;
  overflow: hidden;
  background: var(--white);
  border: 1rpx solid var(--border-soft);
  border-radius: 18rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(29, 43, 39, 0.04);
  transition: transform 0.28s var(--ease-spring), box-shadow 0.28s var(--ease-out-smooth);
}

.card:active {
  transform: scale(0.975);
  box-shadow: 0 2rpx 10rpx rgba(29, 43, 39, 0.08);
}

.empty-card {
  text-align: center;
  padding: 56rpx 32rpx;
  border-style: dashed;
  border-color: var(--border);
  background: linear-gradient(180deg, var(--white) 0%, #f8fbfa 100%);
}

.empty-card .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-title {
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-soft);
}

/* ===== 按钮系统 ===== */

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  border: none;
  border-radius: 14rpx;
  background: linear-gradient(145deg, var(--green-light), var(--green));
  color: var(--white);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 20rpx rgba(29, 111, 95, 0.18);
  transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
}

.primary-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(29, 111, 95, 0.25);
}

.primary-btn[disabled] {
  opacity: 0.45;
  transform: none;
  box-shadow: none;
}

.primary-btn::after {
  border: none;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: none;
  border-radius: 14rpx;
  background: var(--green-ghost);
  color: var(--green);
  font-size: 28rpx;
  font-weight: 500;
  transition: transform 0.12s ease, background 0.12s ease;
}

.ghost-btn:active {
  transform: scale(0.97);
  background: #dff0e8;
}

.ghost-btn::after {
  border: none;
}

/* 所有 button 去掉默认 border */
button::after {
  border: none;
}

/* ===== 表单组件 ===== */

.field {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  background: var(--white);
  border: 1rpx solid var(--border);
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text);
  transition: border-color 0.15s ease;
}

.field:focus {
  border-color: var(--green);
}

.field.textarea {
  min-height: 200rpx;
  height: auto;
  padding: 18rpx 20rpx;
  line-height: 1.6;
}

.picker-field {
  display: flex;
  align-items: center;
  color: var(--text);
}

.picker-field::after {
  content: "›";
  margin-left: auto;
  font-size: 36rpx;
  color: var(--text-muted);
  font-weight: 400;
}

/* ===== 标签 ===== */

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--green-ghost);
  color: var(--green);
  font-size: 22rpx;
  font-weight: 500;
  margin: 6rpx 8rpx 6rpx 0;
  letter-spacing: 0.5rpx;
}

/* ===== 状态标记 ===== */

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  flex-shrink: 0;
  letter-spacing: 0.5rpx;
}

.status-pill.pending {
  background: var(--orange-soft);
  color: var(--orange);
}

.status-pill.waiting {
  background: var(--blue-soft);
  color: var(--blue);
}

.status-pill.chat {
  background: var(--green-ghost);
  color: var(--green);
}

.status-pill.unread {
  background: var(--red-soft);
  color: var(--red);
}

/* ===== 头像上传组件 ===== */

.avatar-picker {
  position: relative;
  display: inline-block;
}

.avatar-picker.large {
  display: block;
}

.avatar-picker-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 16rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(29, 43, 39, 0.52);
  color: var(--white);
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
  transition: background 0.15s ease;
}

.avatar-picker-mask:active {
  background: rgba(29, 43, 39, 0.68);
}

.avatar-picker.large .avatar-picker-mask {
  border-radius: 0 0 999rpx 999rpx;
}

.avatar-picker.circle .avatar-picker-mask {
  border-radius: 0 0 999rpx 999rpx;
}

.avatar-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  margin-top: 18rpx;
  padding: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  transition: transform 0.12s ease;
}

.avatar-action-btn:active {
  transform: scale(0.97);
}

.avatar-action-btn.compact {
  margin-top: 14rpx;
  height: 72rpx;
  font-size: 26rpx;
}

/* ===== 全局动画系统 ===== */

/* 弹簧缓动 — 指尖跟随感 */
:root {
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-out-smooth: cubic-bezier(0.25, 0.1, 0.25, 1);
  --ease-in-smooth: cubic-bezier(0.4, 0, 1, 1);
  --ease-ios: cubic-bezier(0.4, 0, 0.2, 1);
}

.fade-in {
  animation: fadeIn 0.32s var(--ease-out-smooth) both;
}

.slide-up {
  animation: slideUp 0.38s var(--ease-spring) both;
}

.pop-in {
  animation: popIn 0.35s var(--ease-spring) both;
}

.page-enter {
  transition: opacity 0.3s var(--ease-out-smooth), transform 0.3s var(--ease-out-smooth);
}

.page-leaving {
  opacity: 0.5;
  transform: translateY(10rpx);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(48rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}

@keyframes shimmer {
  0%   { background-position: -400rpx 0; }
  100% { background-position: 400rpx 0; }
}

.skeleton {
  background: linear-gradient(90deg, #e8efec 25%, #f3f7f5 50%, #e8efec 75%);
  background-size: 800rpx 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: 10rpx;
}

/* ===== 页面容器 ===== */

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(188rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
