<view class="page">
  <view wx:if="{{post}}" class="card detail-card">
    <view class="card-tools">
      <text class="report-link" bindtap="reportPost">举报</text>
    </view>
    <view class="publisher-row" bindtap="goUser">
      <image class="avatar" src="{{post.publisher.avatarUrl}}" mode="aspectFill" />
      <view>
        <view class="nickname">{{post.publisher.nickname}}</view>
        <view class="muted">{{post.publisher.gender}} · {{post.publisher.grade}} · {{post.publisher.college}}</view>
      </view>
    </view>

    <text class="tag">{{post.category}}</text>
    <view class="section-title">{{post.title}}</view>
    <view class="detail-text">{{post.detail}}</view>
    <view class="info">时间：{{post.timeText}}</view>
    <view class="info">地点：{{post.activityLocation}}</view>
    <view class="info">费用：{{post.feePref}}</view>

    <view wx:if="{{conflict && conflict.blocksApply}}" class="conflict-box conflict-block">
      <view class="conflict-title">时间撞期了，暂时没法申请</view>
      <block wx:for="{{conflict.scheduleConflicts}}" wx:key="postId">
        <view class="muted">和「{{item.title}}」时间重叠，先调整已有安排吧。</view>
      </block>
    </view>

    <view wx:elif="{{conflict && conflict.busyConflicts && conflict.busyConflicts.length}}" class="conflict-box">
      <view class="conflict-title">小提醒</view>
      <block wx:for="{{conflict.busyConflicts}}" wx:key="*this">
        <view class="muted">{{item.overlap.date}} {{item.overlap.startTime}}-{{item.overlap.endTime}} 你标记为忙碌</view>
      </block>
      <view class="muted">只是提醒，不影响你继续申请。</view>
    </view>

    <button class="primary-btn" loading="{{applying}}" disabled="{{applying || post.isMine || (conflict && conflict.blocksApply)}}" bindtap="apply">{{post.isMine ? '这是你发起的' : ((conflict && conflict.blocksApply) ? '时间冲突，暂不可申请' : '申请想搭')}}</button>
  </view>
</view>
