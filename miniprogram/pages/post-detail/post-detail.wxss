.detail-card {
  position: relative;
  padding-top: 52rpx;
}

.card-tools {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  z-index: 1;
}

.report-link {
  color: #8a9692;
  font-size: 24rpx;
  line-height: 1;
}

.publisher-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e6efeb;
}

.nickname {
  font-size: 30rpx;
  font-weight: 700;
}

.detail-text {
  font-size: 30rpx;
  line-height: 1.65;
  margin-bottom: 20rpx;
}

.info {
  font-size: 27rpx;
  color: #33443f;
  line-height: 1.8;
}

.conflict-box {
  margin-top: 22rpx;
  padding: 18rpx;
  border: 1rpx solid #f0c36b;
  border-radius: 10rpx;
  background: #fff8e6;
}

.conflict-title {
  color: #8a5a00;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

button {
  margin-top: 24rpx;
}
