.detail-page { padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }

.detail-card { position: relative; padding: 0; overflow: hidden; }

.detail-cover { width: 100%; display: block; }

.detail-tags { display: flex; flex-wrap: wrap; gap: 8rpx; padding: 18rpx 24rpx 0; }
.wf-tag { padding: 4rpx 12rpx; border-radius: 999rpx; font-size: 20rpx; color: var(--text-muted); background: rgba(0,0,0,0.03); }

.detail-head { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx 0; }

.detail-cat { padding: 6rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 500; letter-spacing: 0.5rpx; background: var(--green-ghost); color: var(--green); }
.detail-cat.food { background: var(--orange-soft); color: #c8741d; }
.detail-cat.sport { background: var(--blue-soft); color: #3d7fd4; }
.detail-cat.study { background: #eaf7ef; color: #2f8f57; }
.detail-cat.fun { background: #f7ecfb; color: #9b4fbb; }

.report-link { font-size: 24rpx; color: var(--text-muted); }

.detail-title { padding: 20rpx 24rpx 0; font-size: 38rpx; font-weight: 700; line-height: 1.3; }
.detail-text { padding: 14rpx 24rpx 0; font-size: 28rpx; line-height: 1.65; color: var(--text-soft); }

.detail-meta { padding: 20rpx 24rpx 0; display: flex; flex-direction: column; gap: 10rpx; }
.detail-row { font-size: 26rpx; color: var(--text-soft); }

.detail-publisher { display: flex; align-items: center; gap: 14rpx; padding: 24rpx; margin-top: 20rpx; border-top: 1rpx solid var(--border-soft); }
.wf-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e5eeea; flex-shrink: 0; }
.wf-name { font-size: 28rpx; font-weight: 600; }
.detail-pub-meta { font-size: 23rpx; color: var(--text-muted); margin-left: auto; }

.conflict-box { margin: 20rpx 24rpx 0; padding: 18rpx; border-radius: 12rpx; background: #fff8e6; border: 1rpx solid #f0c36b; }
.conflict-block { border-color: #e07a7a; background: #fff1f1; }
.conflict-block .conflict-title { color: #b42318; }
.conflict-title { color: #8a5a00; font-size: 28rpx; font-weight: 700; margin-bottom: 8rpx; }

button { margin: 24rpx 24rpx 0; }
