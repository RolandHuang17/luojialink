<view class="page">
  <view class="section-title">举报反馈</view>

  <view class="card">
    <view class="field-label">目标类型</view>
    <picker mode="selector" range="{{targetTypeLabels}}" value="{{targetTypeIndex}}" bindchange="onTypeChange">
      <view class="field picker-field">{{targetTypeLabels[targetTypeIndex]}}</view>
    </picker>

    <view class="field-label">目标 ID</view>
    <input class="field" type="number" value="{{targetId}}" placeholder="例如请求或会话 ID" bindinput="onTargetIdInput" />

    <view class="field-label">举报原因</view>
    <picker mode="selector" range="{{reasons}}" value="{{reasonIndex}}" bindchange="onReasonChange">
      <view class="field picker-field">{{reasons[reasonIndex]}}</view>
    </picker>

    <view class="field-label">补充说明</view>
    <textarea class="field textarea" maxlength="300" value="{{detail}}" placeholder="可选，最多 300 字" bindinput="onDetailInput" />

    <button class="primary-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitReport">提交举报</button>
  </view>
</view>
