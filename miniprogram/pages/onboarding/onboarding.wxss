.onboarding-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flow {
  width: 100%;
}

.progress {
  color: #6f7f7a;
  font-size: 25rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 36rpx;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.option {
  min-height: 88rpx;
  padding: 20rpx;
  border: 1rpx solid #d8e2de;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 28rpx;
  line-height: 1.35;
}

.option.selected {
  border-color: #1d6f5f;
  background: #edf7f2;
  color: #1d6f5f;
  font-weight: 700;
}

.textarea {
  min-height: 260rpx;
  width: 100%;
  box-sizing: border-box;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-top: 18rpx;
  background: #e8efec;
}

.hint {
  grid-column: 1 / -1;
  color: #697a75;
  font-size: 25rpx;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 42rpx;
}

.small-btn {
  flex: 1;
}

.welcome {
  text-align: center;
}
