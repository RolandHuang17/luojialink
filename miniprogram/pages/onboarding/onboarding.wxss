.onboarding-page {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
}

.flow {
  width: 100%;
}

.section-label {
  display: inline-block;
  margin-bottom: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf7f2;
  color: #1d6f5f;
  font-size: 24rpx;
  font-weight: 700;
}

.hint-top {
  margin: -18rpx 0 28rpx;
  color: #697a75;
  font-size: 27rpx;
  line-height: 1.5;
}

.mbti-grid .option {
  grid-column: 1 / -1;
}

.mbti-preview {
  grid-column: 1 / -1;
  margin-bottom: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #edf7f2;
  color: #1d6f5f;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-align: center;
}

.mbti-letter {
  margin-top: 8rpx;
  color: #697a75;
  font-size: 24rpx;
  font-weight: 700;
}

.option.selected .mbti-letter {
  color: #1d6f5f;
}

.welcome-brand {
  margin-bottom: 12rpx;
  color: #1d6f5f;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.progress {
  color: #6f7f7a;
  font-size: 25rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 36rpx;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.option {
  min-height: 88rpx;
  padding: 20rpx;
  border: 1rpx solid #d8e2de;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 28rpx;
  line-height: 1.35;
}

.option.selected {
  border-color: #1d6f5f;
  background: #edf7f2;
  color: #1d6f5f;
  font-weight: 700;
}

.wheel-card {
  padding: 18rpx 0 10rpx;
  border: 1rpx solid #d8e2de;
  border-radius: 16rpx;
  background: #ffffff;
}

.wheel-picker {
  width: 100%;
  height: 340rpx;
}

.wheel-item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  color: #263732;
  font-size: 42rpx;
  font-weight: 800;
}

.wheel-indicator {
  height: 88rpx;
  border-top: 1rpx solid #d8e2de;
  border-bottom: 1rpx solid #d8e2de;
}

.wheel-hint {
  padding-bottom: 10rpx;
  color: #697a75;
  font-size: 25rpx;
  text-align: center;
}

.textarea {
  min-height: 260rpx;
  width: 100%;
  box-sizing: border-box;
}

.avatar-preview {
  display: block;
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #e8efec;
}

.avatar-step-hint {
  margin-top: 18rpx;
  text-align: center;
}

.avatar-step .avatar-action-btn {
  margin-top: 24rpx;
}

.hint {
  grid-column: 1 / -1;
  color: #697a75;
  font-size: 25rpx;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  display: flex;
  box-sizing: border-box;
  gap: 18rpx;
  margin-top: 0;
  padding: 22rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(246, 248, 247, 0), #f6f8f7 28%);
}

.small-btn {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0;
  margin: 0;
  border-radius: 14rpx;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1;
}

.primary-btn[disabled] {
  opacity: 0.45;
}

.welcome {
  text-align: center;
}
