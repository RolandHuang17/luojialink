.form-card {
  padding-bottom: 12rpx;
}

.form-section {
  margin-bottom: 8rpx;
}

.form-section:last-of-type {
  margin-bottom: 0;
}

.label {
  margin: 8rpx 0 12rpx;
  color: #33443f;
  font-size: 28rpx;
  font-weight: 800;
}

.sub-label {
  margin-bottom: 10rpx;
  color: #697a75;
  font-size: 24rpx;
  font-weight: 700;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
}

.picker-field {
  color: #1d2b27;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.action-btn {
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
}
