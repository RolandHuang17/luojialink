.form-card {
  padding-bottom: 12rpx;
}

.cover-picker {
  position: relative; border-radius: 14rpx; overflow: hidden;
  background: var(--bg); border: 2rpx dashed var(--border);
}
.cover-preview { width: 100%; height: 280rpx; display: block; }
.cover-placeholder {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 200rpx; gap: 12rpx;
}
.cover-plus { font-size: 56rpx; color: var(--text-muted); font-weight: 300; line-height: 1; }
.cover-hint { font-size: 25rpx; color: var(--text-muted); }
.cover-uploading {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.7); font-size: 26rpx; color: var(--green); font-weight: 500;
}

.media-type-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.media-type-chip {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 14rpx;
  color: var(--text-soft);
  background: var(--white);
  border: 1rpx solid var(--border);
  font-size: 25rpx;
  font-weight: 700;
}

.media-type-chip.active {
  color: var(--green);
  background: var(--green-ghost);
  border-color: var(--green);
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.album-item,
.album-add {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 14rpx;
  overflow: hidden;
  background: var(--bg);
  border: 1rpx solid var(--border);
}

.album-img {
  width: 100%;
  height: 100%;
  display: block;
}

.album-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-style: dashed;
}

.album-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 50%;
  color: #fff;
  background: rgba(0, 0, 0, 0.42);
  font-size: 30rpx;
}

.upload-tip {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.tag-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-chip {
  padding: 10rpx 22rpx; border-radius: 999rpx;
  font-size: 25rpx; font-weight: 500;
  background: var(--white); border: 1rpx solid var(--border);
  color: var(--text-soft); transition: all 0.15s ease;
}
.tag-chip.active {
  background: var(--green-ghost); border-color: var(--green);
  color: var(--green); font-weight: 600;
}

.form-section {
  margin-bottom: 8rpx;
}

.form-section:last-of-type {
  margin-bottom: 0;
}

.label {
  margin: 8rpx 0 12rpx;
  color: #33443f;
  font-size: 28rpx;
  font-weight: 800;
}

.sub-label {
  margin-bottom: 10rpx;
  color: #697a75;
  font-size: 24rpx;
  font-weight: 700;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
}

.picker-field {
  color: #1d2b27;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.action-btn {
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
}
