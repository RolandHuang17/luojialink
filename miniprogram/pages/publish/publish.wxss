.label {
  font-size: 26rpx;
  font-weight: 700;
  margin: 18rpx 0 10rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
}

.picker-field {
  color: #1d2b27;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

button {
  margin-top: 20rpx;
}
