<view class="page square-page">
  <view class="page-hero">
    <view class="page-title">今天想约点什么？</view>
    <view class="page-subtitle">饭搭子、运动搭子、自习搭子，都在这儿。</view>
  </view>

  <scroll-view scroll-x class="category-scroll" show-scrollbar="{{false}}" enhanced>
    <view class="category-row">
      <block wx:for="{{categories}}" wx:key="name">
        <view class="category-pill {{item.color}} {{activeCategory === item.name ? 'active' : ''}}" data-category="{{item.name}}" bindtap="switchCategory">
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-label">{{item.name}}</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <view wx:if="{{loading && posts.length === 0}}" class="card loading-card">
    <view class="loading-text">加载中…</view>
  </view>

  <view class="post-list">
    <block wx:for="{{posts}}" wx:key="id">
      <view class="card post-card {{item.color}}" bindtap="goDetail" data-id="{{item.id}}">
        <view class="post-accent"></view>
        <view class="post-head">
          <image class="avatar" src="{{item.publisher.avatarUrl}}" mode="aspectFill" catchtap="goUser" data-id="{{item.publisher.id}}" />
          <view class="publisher">
            <view class="publisher-name">{{item.publisher.nickname}}</view>
            <view class="muted mini publisher-sub">{{item.publisher.gender}} · {{item.publisher.grade}} · {{item.publisher.college}}</view>
          </view>
          <text class="category-tag {{item.color}}">{{item.category}}</text>
        </view>
        <view class="post-title">{{item.title}}</view>
        <view class="meta-row">
          <text class="meta-icon">🕒</text>
          <text class="meta-text">{{item.timeText}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-icon">📍</text>
          <text class="meta-text">{{item.activityLocation}}</text>
        </view>
        <view class="post-foot muted mini">发布于 {{item.postedAtText}}</view>
      </view>
    </block>
  </view>

  <view wx:if="{{!loading && posts.length === 0}}" class="card empty-card">
    <view class="empty-title">这里还没有想搭</view>
    <view class="muted">不如点下方 + 号，发一条你的小计划？</view>
  </view>
</view>
