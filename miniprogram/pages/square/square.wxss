.square-page {
  display: flex;
  flex-direction: column;
}

.category-scroll {
  width: 100%;
  height: 88rpx;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  height: 88rpx;
  padding-right: 8rpx;
  box-sizing: border-box;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  height: 72rpx;
  box-sizing: border-box;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  background: #ffffff;
  border: 1rpx solid #e3ebe7;
  box-shadow: 0 6rpx 16rpx rgba(31, 51, 45, 0.04);
  flex-shrink: 0;
}

.category-icon {
  font-size: 28rpx;
  line-height: 1;
}

.category-label {
  line-height: 1;
}

.category-pill.active {
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 10rpx 22rpx rgba(31, 51, 45, 0.12);
}

.category-pill.all.active {
  background: linear-gradient(145deg, #248b76, #1d6f5f);
}

.category-pill.food.active {
  background: linear-gradient(145deg, #f5b56a, #e8943f);
}

.category-pill.sport.active {
  background: linear-gradient(145deg, #6eb5e6, #4a93cf);
}

.category-pill.study.active {
  background: linear-gradient(145deg, #7ec596, #52a873);
}

.category-pill.fun.active {
  background: linear-gradient(145deg, #d49de6, #b06ec8);
}

.loading-card {
  margin-bottom: 22rpx;
  padding: 36rpx 24rpx;
  text-align: center;
}

.loading-text {
  color: #697a75;
  font-size: 26rpx;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.post-list .card {
  margin-bottom: 0;
}

.post-card {
  padding-left: 30rpx;
}

.post-accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: #52a873;
}

.post-card.food .post-accent {
  background: #e8943f;
}

.post-card.sport .post-accent {
  background: #4a93cf;
}

.post-card.study .post-accent {
  background: #52a873;
}

.post-card.fun .post-accent {
  background: #b06ec8;
}

.post-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #e5eeea;
  border: 3rpx solid #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(31, 51, 45, 0.08);
  flex-shrink: 0;
}

.publisher {
  flex: 1;
  min-width: 0;
}

.publisher-name {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.publisher-sub {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 1.45;
}

.mini {
  font-size: 23rpx;
  margin-top: 4rpx;
}

.category-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-tag.food {
  background: #fff3e6;
  color: #c8741d;
}

.category-tag.sport {
  background: #eaf3ff;
  color: #3d7fd4;
}

.category-tag.study {
  background: #eaf7ef;
  color: #2f8f57;
}

.category-tag.fun {
  background: #f7ecfb;
  color: #9b4fbb;
}

.post-title {
  margin: 22rpx 0 16rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-word;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.meta-icon {
  width: 34rpx;
  font-size: 26rpx;
  line-height: 1.45;
  flex-shrink: 0;
  text-align: center;
}

.meta-text {
  flex: 1;
  min-width: 0;
  color: #33443f;
  font-size: 26rpx;
  line-height: 1.55;
  word-break: break-word;
}

.post-foot {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #eef3f1;
}
