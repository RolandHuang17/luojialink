.explore-page {
  display: flex; flex-direction: column;
  padding-left: 16rpx; padding-right: 16rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background: var(--bg-explore);
}

.square-switch {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 8rpx; padding: 8rpx; margin-bottom: 16rpx;
  background: rgba(255,255,255,0.78);
  border: 1rpx solid rgba(29,111,95,0.08);
  border-radius: 999rpx;
  box-shadow: 0 6rpx 18rpx rgba(31,51,45,0.04);
}
.switch-item {
  height: 58rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 999rpx; color: var(--text-muted);
  font-size: 25rpx; font-weight: 500;
}
.switch-item.active {
  color: var(--white);
  background: linear-gradient(145deg, var(--green-light), var(--green));
  box-shadow: 0 8rpx 18rpx rgba(29,111,95,0.18);
}

/* ===== 分类栏 ===== */
.cat-bar { width: 100%; height: 76rpx; margin-bottom: 20rpx; white-space: nowrap; }
.cat-row { display: inline-flex; align-items: center; gap: 12rpx; height: 76rpx; padding: 0 4rpx; }
.cat-pill {
  display: inline-flex; align-items: center; height: 60rpx; padding: 0 20rpx;
  border-radius: 999rpx; font-size: 25rpx; font-weight: 500;
  background: var(--white); border: 1rpx solid var(--border);
  box-shadow: 0 4rpx 12rpx rgba(31,51,45,0.03);
  transition: all 0.2s var(--ease-out-smooth);
}
.cat-pill:active { transform: scale(0.95); }
.cat-pill.active { color: var(--white); border-color: transparent; }
.cat-pill.all.active { background: linear-gradient(145deg, var(--green-light), var(--green)); }
.cat-pill.food.active { background: linear-gradient(145deg, #f5b56a, #e8943f); }
.cat-pill.sport.active { background: linear-gradient(145deg, #6eb5e6, #4a93cf); }
.cat-pill.study.active { background: linear-gradient(145deg, #7ec596, #52a873); }
.cat-pill.fun.active { background: linear-gradient(145deg, #d49de6, #b06ec8); }

.recommend-panel {
  padding: 22rpx; margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.92);
}
.recommend-head {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 16rpx; margin-bottom: 18rpx;
}
.recommend-title { font-size: 30rpx; font-weight: 700; color: var(--text); line-height: 1.25; }
.recommend-sub { margin-top: 4rpx; font-size: 23rpx; color: var(--text-muted); }
.recommend-action {
  flex-shrink: 0; padding: 10rpx 18rpx; border-radius: 999rpx;
  color: var(--green); background: rgba(29,111,95,0.08);
  font-size: 23rpx; font-weight: 600;
}
.recommend-fields {
  display: grid; grid-template-columns: 1.18fr 1fr 1fr;
  gap: 12rpx; margin-bottom: 18rpx;
}
.recommend-field {
  min-width: 0; padding: 14rpx 12rpx;
  border-radius: 14rpx; background: rgba(29,111,95,0.045);
}
.field-label {
  display: block; margin-bottom: 4rpx;
  font-size: 21rpx; color: var(--text-muted);
}
.field-value {
  display: block; font-size: 24rpx; font-weight: 600;
  color: var(--text); white-space: nowrap;
}
.recommend-cats { display: flex; flex-wrap: wrap; gap: 10rpx; }
.recommend-cat {
  padding: 10rpx 18rpx; border-radius: 999rpx;
  font-size: 23rpx; color: var(--text-muted);
  background: rgba(0,0,0,0.035);
  border: 1rpx solid transparent;
}
.recommend-cat.active {
  color: var(--green); background: rgba(29,111,95,0.08);
  border-color: rgba(29,111,95,0.12);
  font-weight: 600;
}
.recommend-cat.food.active { color: #c8741d; background: rgba(232,148,63,0.10); }
.recommend-cat.sport.active { color: #3d7fd4; background: rgba(74,147,207,0.10); }
.recommend-cat.study.active { color: #2f8f57; background: rgba(82,168,115,0.10); }
.recommend-cat.fun.active { color: #9b4fbb; background: rgba(176,110,200,0.10); }

/* ===== 瀑布流 ===== */
.wf-row { display: flex; gap: 16rpx; align-items: flex-start; }
.wf-col { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 20rpx; }

/* ===== 卡片 ===== */
.wf-card {
  padding: 0; margin-bottom: 0;
  border-radius: 16rpx; overflow: hidden;
  border: 1rpx solid rgba(0,0,0,0.04);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
  transition: transform 0.2s var(--ease-spring);
}
.wf-card:active { transform: scale(0.97); }

/* ===== 多媒体封面容器 ===== */
.wf-media-cover { position: relative; width: 100%; }
.wf-cover-img { width: 100%; display: block; }

/* ===== 角标通用 ===== */
.wf-badge {
  position: absolute; top: 16rpx; right: 16rpx;
  z-index: 2;
}

/* 左上角分类标签 */
.wf-badge-cat {
  top: 16rpx; left: 16rpx; right: auto;
  padding: 6rpx 14rpx; border-radius: 999rpx;
  font-size: 22rpx; font-weight: 500;
  background: rgba(255,255,255,0.88);
  color: var(--text);
  letter-spacing: 0.5rpx;
}
.wf-badge-cat.food { color: #c8741d; }
.wf-badge-cat.sport { color: #3d7fd4; }
.wf-badge-cat.study { color: #2f8f57; }
.wf-badge-cat.fun  { color: #9b4fbb; }

/* 视频角标 — 圆形半透明黑底 + 播放三角 */
.wf-badge-video {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(0,0,0,0.35);
  display: flex; align-items: center; justify-content: center;
}
.wf-play-icon {
  width: 0; height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 20rpx solid rgba(255,255,255,0.92);
  margin-left: 5rpx;
}

/* 相册角标 — 胶囊背景 + 叠层图标 + 数字 */
.wf-badge-album {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: rgba(0,0,0,0.35);
}
.wf-album-icon { position: relative; width: 24rpx; height: 24rpx; }
.wf-album-stack {
  position: absolute; inset: 0; border-radius: 4rpx;
  background: rgba(255,255,255,0.9);
  box-shadow: -4rpx -4rpx 0 rgba(255,255,255,0.55);
}
.wf-album-count {
  font-size: 22rpx; font-weight: 500; color: rgba(255,255,255,0.9);
  line-height: 1;
}

/* ===== 纯文字卡片 ===== */
.wf-text-card {
  position: relative; overflow: hidden;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  display: flex; flex-direction: column; gap: 18rpx;
  border-left: 6rpx solid var(--green);
}
/* 宽高比 */
.ratio-4-3 { min-height: 200rpx; }
.ratio-1-1 { min-height: 260rpx; }
.ratio-3-4 { min-height: 320rpx; }

/* 水印引号 */
.wf-text-quote {
  position: absolute; right: 12rpx; bottom: -14rpx;
  font-size: 120rpx; font-weight: 800; line-height: 1;
  color: rgba(0,0,0,0.03);
  font-family: Georgia, "Times New Roman", serif;
  pointer-events: none;
}

.wf-text-body { position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column; gap: 14rpx; }
.wf-text-tag {
  display: inline-block; width: fit-content;
  padding: 4rpx 14rpx; border-radius: 999rpx;
  font-size: 22rpx; font-weight: 500; letter-spacing: 0.5rpx;
  background: rgba(29,111,95,0.08); color: var(--green);
}
.wf-text-content {
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 6;
  overflow: hidden; word-break: break-word;
  font-size: 26rpx; font-weight: 500; line-height: 1.5; color: var(--text-soft);
}

/* ===== 9 种弥散渐变（纯文字卡片背景） ===== */
.mesh-warm  { background: radial-gradient(ellipse 60% 50% at 20% 30%, #fdf2e9 0%, transparent 70%), radial-gradient(ellipse 50% 60% at 80% 70%, #fbe4d0 0%, transparent 70%), #fff8f3; }
.mesh-peach { background: radial-gradient(ellipse 55% 45% at 70% 20%, #fef0e8 0%, transparent 65%), radial-gradient(ellipse 45% 55% at 30% 80%, #ffdcc6 0%, transparent 65%), #fffaf6; }
.mesh-sunset{ background: radial-gradient(ellipse 50% 60% at 40% 50%, #fef3e4 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 40%, #ffe2cc 0%, transparent 60%), #fef6ed; }
.mesh-mint  { background: radial-gradient(ellipse 55% 50% at 30% 30%, #e8f5ef 0%, transparent 70%), radial-gradient(ellipse 50% 60% at 70% 70%, #d4ede0 0%, transparent 70%), #f4faf7; }
.mesh-fresh { background: radial-gradient(ellipse 60% 50% at 80% 20%, #eaf7f0 0%, transparent 65%), radial-gradient(ellipse 45% 55% at 20% 80%, #cfe8da 0%, transparent 65%), #f8fcfa; }
.mesh-ocean { background: radial-gradient(ellipse 50% 60% at 40% 50%, #edf5fc 0%, transparent 60%), radial-gradient(ellipse 55% 40% at 70% 40%, #dceaf7 0%, transparent 60%), #f4f9fd; }
.mesh-lavender{ background: radial-gradient(ellipse 55% 50% at 30% 30%, #f5effa 0%, transparent 70%), radial-gradient(ellipse 50% 55% at 80% 70%, #e6d8f2 0%, transparent 70%), #faf7fc; }
.mesh-rose { background: radial-gradient(ellipse 60% 50% at 70% 20%, #fdf0f3 0%, transparent 65%), radial-gradient(ellipse 45% 55% at 20% 80%, #f5dde4 0%, transparent 65%), #fff8f9; }
.mesh-sky  { background: radial-gradient(ellipse 50% 60% at 50% 50%, #eef6fc 0%, transparent 60%), radial-gradient(ellipse 55% 40% at 60% 40%, #dceef8 0%, transparent 60%), #f6fafd; }

/* 自选标签 */
.wf-tags { display: flex; flex-wrap: wrap; gap: 8rpx; padding: 0 16rpx 12rpx; }
.wf-tag {
  padding: 4rpx 12rpx; border-radius: 999rpx;
  font-size: 20rpx; font-weight: 400; color: var(--text-muted);
  background: rgba(0,0,0,0.03);
}

.recommend-reason {
  display: flex; gap: 10rpx; align-items: flex-start;
  margin: 0 16rpx 12rpx; padding: 12rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, rgba(29,111,95,0.08), rgba(82,168,115,0.035));
}
.score-pill {
  flex-shrink: 0;
  min-width: 64rpx; height: 40rpx; padding: 0 10rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 999rpx;
  background: var(--green); color: var(--white);
  font-size: 21rpx; font-weight: 700;
}
.reason-lines {
  min-width: 0; display: flex; flex-direction: column; gap: 4rpx;
  font-size: 21rpx; line-height: 1.35; color: var(--text-muted);
}

/* ===== 统一底部栏 ===== */
.wf-foot {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 16rpx 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
}
.wf-author { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; max-width: 68%; }
.wf-avatar {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #e5eeea; flex-shrink: 0;
}
.wf-name {
  font-size: 24rpx; font-weight: 400; color: var(--text-muted);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.wf-meta { font-size: 22rpx; font-weight: 400; color: var(--text-muted); flex-shrink: 0; }
