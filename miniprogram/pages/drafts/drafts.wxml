<view class="page">
  <view class="section-title">草稿箱</view>

  <block wx:for="{{drafts}}" wx:key="id">
    <view class="card">
      <view class="draft-title">{{item.title}}</view>
      <view class="muted">{{item.category}} · {{item.activityLocation}}</view>
      <view class="actions">
        <button class="primary-btn small-btn" data-id="{{item.id}}" bindtap="editDraft">继续编辑</button>
        <button class="ghost-btn small-btn" data-id="{{item.id}}" bindtap="deleteDraft">删除</button>
      </view>
    </view>
  </block>

  <view wx:if="{{drafts.length === 0}}" class="card muted">暂无草稿。</view>
</view>
