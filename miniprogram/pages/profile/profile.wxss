.me-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e6efeb;
}

.me-main {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 800;
}

.cancel-btn {
  margin-top: 16rpx;
}

.logout {
  margin-top: 26rpx;
}
