.me-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e6efeb;
}

.me-main {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
}

.chevron {
  color: #8a9692;
  font-size: 46rpx;
  line-height: 1;
  padding-left: 8rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.action-tile {
  min-width: 0;
  height: 82rpx;
  border-radius: 10rpx;
  background: #edf5f2;
  color: #1d6f5f;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 82rpx;
  text-align: center;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 800;
}

.cancel-btn {
  margin-top: 16rpx;
}

.logout {
  margin-top: 26rpx;
}
