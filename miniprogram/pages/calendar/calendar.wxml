<view class="page">
  <view class="section-title">智能日历</view>

  <view class="card">
    <view class="form-row">
      <view class="label">日期</view>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="field picker-field">{{form.date}}</view>
      </picker>
    </view>

    <view class="time-grid">
      <view>
        <view class="label">开始</view>
        <picker mode="time" value="{{form.startTime}}" bindchange="onStartChange">
          <view class="field picker-field">{{form.startTime}}</view>
        </picker>
      </view>
      <view>
        <view class="label">结束</view>
        <picker mode="time" value="{{form.endTime}}" bindchange="onEndChange">
          <view class="field picker-field">{{form.endTime}}</view>
        </picker>
      </view>
    </view>

    <view class="form-row">
      <view class="label">状态</view>
      <picker range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="field picker-field">{{statusOptions[statusIndex].label}}</view>
      </picker>
    </view>

    <button class="ghost-btn" bindtap="addSlot">添加时间片</button>
    <button class="primary-btn save-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="saveSlots">保存日历</button>
  </view>

  <view class="section-title">我的时间片</view>
  <block wx:for="{{slots}}" wx:key="id">
    <view class="card slot-card">
      <view>
        <text class="tag {{item.status === 'busy' ? 'busy-tag' : ''}}">{{item.status === 'busy' ? '忙碌' : '空闲'}}</text>
        <text class="slot-time">{{item.date}} {{item.startTime}}-{{item.endTime}}</text>
      </view>
      <button class="ghost-btn remove-btn" bindtap="removeSlot" data-index="{{index}}">删除</button>
    </view>
  </block>
  <view wx:if="{{!loading && slots.length === 0}}" class="card muted">还没有时间片，先添加一个空闲或忙碌时间。</view>
</view>
