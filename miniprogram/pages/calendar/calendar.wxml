<view class="page">
  <view class="section-title">日程</view>
  <view class="muted">红色是我发布的，蓝色是我申请的，绿色是已经搭上的。</view>

  <scroll-view scroll-x class="day-scroll">
    <view class="day-row">
      <block wx:for="{{days}}" wx:key="key">
        <view class="day {{selectedDate === item.key ? 'active' : ''}}" data-date="{{item.key}}" bindtap="selectDate">
          <view class="week">周{{item.week}}</view>
          <view class="number">{{item.day}}</view>
        </view>
      </block>
    </view>
  </scroll-view>

  <block wx:for="{{selectedEvents}}" wx:key="id">
    <view class="card event {{item.color}}" bindtap="goDetail" data-id="{{item.postId}}">
      <view class="row">
        <view class="event-title">{{item.title}}</view>
        <text class="tag">{{item.typeText}}</text>
      </view>
      <view class="muted">{{item.timeText}}</view>
      <view class="muted">{{item.activityLocation}}</view>
    </view>
  </block>

  <view wx:if="{{selectedEvents.length === 0}}" class="card muted">这一天暂时没有安排。</view>
</view>
