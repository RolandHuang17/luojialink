.day-scroll {
  margin: 24rpx 0;
  white-space: nowrap;
}

.day-row {
  display: flex;
  gap: 14rpx;
}

.day {
  flex: 0 0 104rpx;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e0e8e4;
}

.day.active {
  background: #1d6f5f;
  color: #ffffff;
}

.week {
  font-size: 23rpx;
}

.number {
  font-size: 36rpx;
  font-weight: 800;
  margin-top: 6rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.event {
  border-left-width: 10rpx;
}

.event.red {
  border-left-color: #e45c4f;
}

.event.blue {
  border-left-color: #4c91d9;
}

.event.green {
  border-left-color: #41a36f;
}

.event-title {
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.4;
}
