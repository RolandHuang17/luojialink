<view class="page mbti-page">
  <view class="progress">{{index + 1}} / {{questions.length}}</view>
  <view class="title">{{currentQuestion.title}}</view>

  <view class="option-list">
    <block wx:for="{{currentQuestion.options}}" wx:key="value">
      <view class="option {{mbti[index] === item.value ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectOption">
        <view class="option-main">{{item.label}}</view>
        <view class="muted">{{item.value}}</view>
      </view>
    </block>
  </view>

  <view class="actions">
    <button class="ghost-btn small-btn" wx:if="{{index > 0}}" bindtap="prev">上一步</button>
    <button class="primary-btn small-btn" loading="{{saving}}" bindtap="next">{{index === questions.length - 1 ? '保存结果' : '下一题'}}</button>
  </view>
</view>
