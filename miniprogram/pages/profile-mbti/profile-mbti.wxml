<view class="page mbti-page">
  <view class="mbti-preview">当前类型：{{mbtiPreview}}</view>
  <view class="progress">{{questionIndex + 1}} / {{questions.length}}</view>
  <view class="title">{{currentQuestion.title}}</view>

  <view class="option-list">
    <block wx:for="{{currentQuestion.options}}" wx:key="value" wx:for-index="optionIndex">
      <view class="option {{mbti[questionIndex] === item.value ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectOption">
        <view class="option-main">{{item.label}}</view>
        <view class="mbti-letter">{{item.value}}</view>
      </view>
    </block>
  </view>

  <view class="actions">
    <button class="ghost-btn small-btn" wx:if="{{questionIndex > 0}}" bindtap="prev">上一题</button>
    <button class="primary-btn small-btn" loading="{{saving}}" bindtap="next">{{questionIndex === questions.length - 1 ? '保存结果' : '下一题'}}</button>
  </view>
</view>
