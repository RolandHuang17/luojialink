<view class="page login-page">
  <view class="login-hero">
    <view class="brand">LuoJiaLink</view>
    <view class="subtitle">武大同学的搭子小站</view>
  </view>

  <view class="card login-card">
    <view class="section-title">登录 LuoJiaLink</view>
    <view class="muted card-intro">用手机号进入，找到时间合拍的人。</view>

    <view class="form-field">
      <view class="field-label">手机号</view>
      <input class="form-input" type="number" maxlength="11" placeholder="用于演示登录，例如 13800000001" value="{{phoneNumber}}" data-key="phoneNumber" bindinput="onInput" />
    </view>

    <view class="form-field">
      <view class="field-label">昵称（注册时可填）</view>
      <input class="form-input" maxlength="16" placeholder="不填会自动生成" value="{{nickname}}" data-key="nickname" bindinput="onInput" />
    </view>

    <button class="primary-btn login-action" bindtap="loginWithPhone" loading="{{loggingIn}}" disabled="{{loggingIn || registering}}">
      手机号登录
    </button>

    <button class="ghost-btn register-btn" loading="{{registering}}" disabled="{{loggingIn || registering}}" bindtap="register">
      注册账号
    </button>

    <view class="login-note">
      新手机号注册后会进入资料填写；老用户登录后直接进入广场。
    </view>
  </view>
</view>
