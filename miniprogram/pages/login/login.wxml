<view class="page login-page">
  <view class="brand">珞珈连点</view>
  <view class="subtitle">武大学生找搭子 / 找朋友</view>

  <view class="card">
    <view class="section-title">选择测试账号</view>
    <block wx:for="{{accounts}}" wx:key="key">
      <button class="{{index === 0 ? 'primary-btn' : 'ghost-btn'}}" bindtap="login" data-account="{{item.key}}">{{item.name}}</button>
    </block>
  </view>

  <view class="muted">当前使用 mock 登录，本地演示不接入真实统一认证。</view>
</view>
