.chat-room-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.chat-room-page.emoji-open {
  padding-bottom: calc(520rpx + env(safe-area-inset-bottom));
}

.room-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0 24rpx;
  border-bottom: 1rpx solid #e4ece8;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #e6efeb;
  flex-shrink: 0;
}

.header-main {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 32rpx;
  font-weight: 800;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.main-text {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.contact-card,
.ai-card {
  margin-top: 20rpx;
}

.ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.ai-source {
  margin-top: 6rpx;
  color: #697a75;
  font-size: 23rpx;
}

.ai-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #248b76, #1d6f5f);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.ai-section {
  margin-bottom: 16rpx;
}

.ai-label {
  margin-bottom: 6rpx;
  color: #697a75;
  font-size: 23rpx;
  font-weight: 700;
}

.ai-text {
  color: #33443f;
  font-size: 26rpx;
  line-height: 1.5;
}

.icebreaker-box {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f7fbf9 0%, #edf7f2 100%);
  color: #1d2b27;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.55;
}

.ai-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.ai-action {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  background: #edf7f2;
  color: #1d6f5f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.ai-action.primary {
  background: linear-gradient(145deg, #248b76, #1d6f5f);
  color: #ffffff;
}

.ai-action.disabled {
  opacity: 0.55;
}

.pending-thread {
  margin-top: 28rpx;
}

.system-tip {
  width: fit-content;
  max-width: 520rpx;
  margin: 0 auto 28rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e9efec;
  color: #7a8783;
  font-size: 24rpx;
  text-align: center;
}

.closed-tip {
  margin-top: 20rpx;
  background: #fff0ee;
  color: #c45c4f;
}

.cancel-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.cancel-action {
  padding: 10rpx 0;
  color: #c45c4f;
  font-size: 26rpx;
  font-weight: 700;
}

.request-message {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.request-message.mine {
  justify-content: flex-end;
}

.request-card {
  max-width: 520rpx;
  padding: 22rpx;
  border: 1rpx solid #dce7e2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 51, 45, 0.05);
}

.mine-card {
  background: #edf7f2;
  border-color: #cfe5dc;
}

.request-title {
  color: #1d2b27;
  font-size: 30rpx;
  font-weight: 800;
}

.request-post {
  margin-top: 8rpx;
  color: #1d6f5f;
  font-size: 25rpx;
  font-weight: 700;
}

.request-content {
  margin-top: 14rpx;
  color: #33443f;
  font-size: 27rpx;
  line-height: 1.55;
}

.request-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.accept-action,
.reject-action,
.withdraw-action {
  min-width: 108rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.accept-action {
  background: #1d6f5f;
  color: #ffffff;
}

.reject-action,
.withdraw-action {
  background: #edf5f2;
  color: #1d6f5f;
}

.withdraw-action {
  width: fit-content;
  margin-top: 18rpx;
  margin-left: auto;
}

.contact-btn {
  width: 210rpx;
  font-size: 24rpx;
}

.message-list {
  min-height: 360rpx;
  margin: 24rpx 0;
}

.message {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.message.mine {
  justify-content: flex-end;
}

.message-main {
  max-width: 78%;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e6efeb;
  flex-shrink: 0;
}

.message-meta {
  color: #697a75;
  font-size: 23rpx;
  margin-bottom: 6rpx;
}

.message.mine .message-meta {
  text-align: right;
}

.message-bubble {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: flex-end;
  max-width: 100%;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #edf5f2;
  color: #1d2b27;
  text-align: left;
  line-height: 1.45;
}

.message-text {
  word-break: break-word;
  white-space: pre-wrap;
}

.message-emoji {
  width: 42rpx;
  height: 42rpx;
  margin: 0 2rpx;
  vertical-align: bottom;
}

.message.mine .message-bubble {
  background: #1d6f5f;
  color: #ffffff;
}

.empty-message {
  padding: 60rpx 0;
  text-align: center;
}

.composer-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 12;
  background: #ffffff;
  border-top: 1rpx solid #e4ece8;
}

.emoji-panel {
  height: 360rpx;
  background: #f6f8f7;
  border-bottom: 1rpx solid #e4ece8;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 8rpx;
  padding: 16rpx 18rpx 20rpx;
}

.emoji-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 12rpx;
}

.emoji-item:active {
  background: #e9f2ee;
}

.emoji-icon {
  width: 52rpx;
  height: 52rpx;
}

.composer {
  position: static;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: none;
}

.emoji-toggle {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border-radius: 12rpx;
  background: #edf5f2;
  color: #1d6f5f;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.emoji-toggle.active {
  background: #1d6f5f;
  color: #ffffff;
}

.message-input {
  flex: 1;
  margin-bottom: 0;
}

.send-action {
  width: 96rpx;
  height: 72rpx;
  flex: 0 0 96rpx;
  border-radius: 10rpx;
  background: #1d6f5f;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.send-action.disabled {
  opacity: 0.45;
}
