.inbox-list {
  display: grid;
  gap: 16rpx;
}

.conversation-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 0;
  padding: 22rpx 24rpx;
}

.conversation-card.unread {
  border-color: #f3d6d6;
  background: linear-gradient(180deg, #fffafa 0%, #ffffff 100%);
}

.avatar-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e6efeb;
  border: 3rpx solid #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(31, 51, 45, 0.08);
}

.unread-dot {
  position: absolute;
  right: 0;
  top: 0;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #e84b4b;
}

.conversation-main {
  flex: 1;
  min-width: 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 800;
}

.one-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}
