.conversation {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e4ece8;
}

.avatar-wrap {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e6efeb;
}

.unread-dot {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #e84b4b;
}

.conversation-main {
  flex: 1;
  min-width: 0;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
}

.one-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 6rpx;
}

