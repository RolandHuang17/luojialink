.chat-page {
  display: flex;
  flex-direction: column;
}

.inbox-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ===== 会话卡片 ===== */

.conversation-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 0;
  padding: 22rpx 26rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}

.conversation-card:active {
  background: #f9fbfa;
}

.conversation-card.unread {
  border-color: #f0d8d8;
  background: linear-gradient(135deg, #fffafa 0%, #ffffff 60%);
}

/* ===== 头像 ===== */

.avatar-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e6efeb;
  border: 3rpx solid var(--white);
  box-shadow: 0 4rpx 14rpx rgba(31, 51, 45, 0.08);
}

.unread-dot {
  position: absolute;
  right: 0;
  top: 0;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid var(--white);
  border-radius: 50%;
  background: #e84b4b;
  box-shadow: 0 2rpx 6rpx rgba(232, 75, 75, 0.3);
}

/* ===== 会话内容 ===== */

.conversation-main {
  flex: 1;
  min-width: 0;
}

.conv-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.conv-name {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-sub {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
}
