<view class="page chat-page page-enter {{pageLeaving ? 'page-leaving' : ''}}">
  <view class="page-hero">
    <view class="page-title">消息</view>
    <view class="page-subtitle">想搭申请和聊天，都会出现在这里。</view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading && items.length === 0}}" class="inbox-list">
    <view class="card conversation-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton" style="width:88rpx;height:88rpx;border-radius:50%"></view>
      <view class="conversation-main">
        <view class="skeleton" style="width:50%;height:26rpx;margin-bottom:14rpx"></view>
        <view class="skeleton" style="width:78%;height:22rpx"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading || items.length > 0}}" class="inbox-list">
    <block wx:for="{{items}}" wx:key="id">
      <view
        class="card conversation-card {{item.hasUnread ? 'unread' : ''}} slide-up"
        style="animation-delay:{{index * 0.05}}s"
        bindtap="openItem"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
      >
        <view class="avatar-wrap">
          <image class="avatar" src="{{item.peer.avatarUrl}}" mode="aspectFill" />
          <view wx:if="{{item.hasUnread}}" class="unread-dot"></view>
        </view>
        <view class="conversation-main">
          <view class="conv-row">
            <view class="conv-name">{{item.peer.displayName || item.peer.nickname}}</view>
            <view class="status-pill {{item.statusTone}}">{{item.statusText}}</view>
          </view>
          <view class="conv-sub muted">{{item.post.title}}</view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="card empty-card fade-in">
    <view class="empty-icon">💬</view>
    <view class="empty-title">还没有消息</view>
    <view class="muted">申请想搭或开始聊天后，会在这里出现。</view>
  </view>
</view>
