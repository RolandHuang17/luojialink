<view class="page">
  <view class="section-title">消息</view>

  <block wx:for="{{items}}" wx:key="id">
    <view class="conversation {{activeItem && activeItem.id === item.id && activeItem.type === item.type ? 'active' : ''}}" bindtap="selectItem" data-id="{{item.id}}" data-type="{{item.type}}">
      <image class="avatar" src="{{item.peer.avatarUrl}}" mode="aspectFill" />
      <view class="conversation-main">
        <view class="row">
          <view class="name">{{item.peer.nickname}}</view>
          <view class="muted">{{item.status}}</view>
        </view>
        <view class="muted one-line">{{item.post.title}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{!loading && items.length === 0}}" class="card muted">申请和会话会出现在这里。</view>

  <view wx:if="{{activeItem}}" class="card panel">
    <view class="row">
      <view>
        <view class="main-text">{{activeItem.post.title}}</view>
        <view class="muted">{{activeItem.peer.nickname}} · {{activeItem.peer.college}}</view>
      </view>
      <text class="tag">{{activeItem.type === 'application' ? '申请' : '会话'}}</text>
    </view>

    <view wx:if="{{activeItem.type === 'application'}}" class="application-box">
      <view class="muted">申请说明</view>
      <view class="apply-message">{{activeItem.applyMessage || '对方想加入这个想搭。'}}</view>
      <view wx:if="{{activeItem.isPublisher}}" class="actions">
        <button class="primary-btn small-btn" bindtap="acceptApplication">通过</button>
        <button class="ghost-btn small-btn" bindtap="rejectApplication">拒绝</button>
      </view>
      <button wx:else class="ghost-btn" bindtap="withdrawApplication">撤回申请</button>
      <view class="muted pending-tip">申请通过前不能自由聊天。</view>
    </view>

    <view wx:else>
      <view class="contact-card">
        <view class="row">
          <view>
            <view class="sub-title">联系方式</view>
            <view wx:if="{{activeItem.contactVisible}}" class="main-text">微信号：{{activeItem.peer.wechatId}}</view>
            <view wx:else class="muted">双方都点击互换后可见。</view>
          </view>
          <button class="ghost-btn contact-btn" bindtap="exchangeContact">{{activeItem.contactSharedByMe ? '等待对方' : '互换联系方式'}}</button>
        </view>
      </view>

      <view wx:if="{{recommendation}}" class="recommendation">
        <view class="sub-title">智能建议</view>
        <view class="muted">{{recommendation.timeSuggestion.text}}</view>
        <view>{{recommendation.placeSuggestion.name}} · {{recommendation.placeSuggestion.location}}</view>
        <view class="muted">{{recommendation.icebreaker}}</view>
      </view>

      <view class="message-list">
        <block wx:for="{{messages}}" wx:key="id">
          <view class="message {{item.isMine ? 'mine' : 'theirs'}}">
            <view class="message-meta">{{item.sender.nickname}}</view>
            <view class="message-bubble">{{item.content}}</view>
          </view>
        </block>
        <view wx:if="{{messages.length === 0}}" class="muted empty-message">暂无消息，先打个招呼。</view>
      </view>

      <view class="composer">
        <input class="field message-input" value="{{messageText}}" placeholder="输入消息" bindinput="onInput" />
        <button class="primary-btn send-btn" loading="{{sending}}" disabled="{{sending || !messageText}}" bindtap="sendMessage">发送</button>
      </view>
    </view>

    <button class="ghost-btn report-btn" bindtap="reportSession">举报</button>
  </view>
</view>
