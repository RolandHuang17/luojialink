<view class="page">
  <view class="section-title">临时会话</view>

  <block wx:for="{{sessions}}" wx:key="id">
    <view class="card session-card {{activeSessionId === item.id ? 'active-session' : ''}}" bindtap="selectSession" data-id="{{item.id}}">
      <view class="row">
        <text class="tag">{{item.post.category}}</text>
        <text class="muted">{{item.status}}</text>
      </view>
      <view class="main-text">{{item.peer.nickname}} · {{item.peer.college}}</view>
      <view class="muted">{{item.post.description}}</view>
      <view class="muted">{{item.post.locationPref}} · {{item.post.feePref}}</view>
      <view wx:if="{{item.lastMessage}}" class="muted last-message">最近：{{item.lastMessage.content}}</view>
    </view>
  </block>

  <view wx:if="{{!loading && sessions.length === 0}}" class="card">
    <view class="muted">确认匹配后会在这里出现临时会话。</view>
  </view>

  <view wx:if="{{activeSession}}" class="card message-panel">
    <view class="row">
      <view>
        <view class="main-text">与 {{activeSession.peer.nickname}} 的会话</view>
        <view class="muted">{{activeSession.post.description}}</view>
      </view>
      <text class="tag">{{activeSession.status}}</text>
    </view>

    <view class="common-free">
      <view class="sub-title">共同空闲</view>
      <block wx:for="{{commonFree}}" wx:key="startTime">
        <text class="tag">{{item.date}} {{item.startTime}}-{{item.endTime}}</text>
      </block>
      <view wx:if="{{commonFree.length === 0}}" class="muted">暂无共同空闲，可以先在聊天里确认时间。</view>
    </view>

    <view class="recommendation">
      <view class="sub-title">智能建议</view>
      <view wx:if="{{recommendationLoading}}" class="muted">正在生成建议...</view>
      <view wx:elif="{{recommendation}}">
        <view class="recommendation-item">
          <text class="label">时间</text>
          <text>{{recommendation.timeSuggestion.text}}</text>
        </view>
        <view class="recommendation-item">
          <text class="label">地点</text>
          <text>{{recommendation.placeSuggestion.name}} · {{recommendation.placeSuggestion.location}}</text>
        </view>
        <view class="recommendation-item">
          <text class="label">破冰</text>
          <text>{{recommendation.icebreaker}}</text>
        </view>
        <block wx:for="{{recommendation.notes}}" wx:key="*this">
          <view class="muted note">- {{item}}</view>
        </block>
      </view>
      <view wx:else class="muted">选择会话后生成建议。</view>
    </view>

    <view wx:if="{{recommendedPois.length > 0}}" class="poi-list">
      <view class="sub-title">推荐地点</view>
      <block wx:for="{{recommendedPois}}" wx:key="id">
        <view class="poi-item">
          <view>{{item.name}}</view>
          <view class="muted">{{item.location}} · 评分 {{item.rating}}</view>
        </view>
      </block>
    </view>

    <view class="message-list">
      <block wx:for="{{messages}}" wx:key="id">
        <view class="message {{item.isMine ? 'mine' : 'theirs'}}">
          <view class="message-meta">{{item.sender.nickname}}</view>
          <view class="message-bubble">{{item.content}}</view>
        </view>
      </block>
      <view wx:if="{{messages.length === 0}}" class="muted empty-message">暂无消息，先打个招呼。</view>
    </view>

    <view class="composer">
      <input class="field message-input" value="{{messageText}}" placeholder="输入消息" bindinput="onInput" />
      <button class="primary-btn send-btn" loading="{{sending}}" disabled="{{sending || !messageText}}" bindtap="sendMessage">发送</button>
    </view>

    <button class="ghost-btn report-btn" bindtap="reportSession">举报会话</button>
  </view>
</view>
