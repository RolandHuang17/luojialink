<view class="tab-shell">
  <view class="tab-bar">
    <block wx:for="{{list}}" wx:key="pagePath">
      <view class="tab-item {{selected === index ? 'active' : ''}} {{item.isPublish ? 'publish' : ''}}" data-index="{{index}}" data-path="{{item.pagePath}}" bindtap="switchTab">
        <view wx:if="{{item.badge}}" class="tab-dot"></view>
        <view class="tab-icon">{{item.icon}}</view>
        <view class="tab-text">{{item.text}}</view>
      </view>
    </block>
  </view>
</view>
