.tab-shell {
  padding: 4rpx 22rpx calc(6rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #dfe8e4;
  box-shadow: 0 -8rpx 28rpx rgba(31, 51, 45, 0.06);
}

.tab-bar {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  min-height: 96rpx;
  gap: 8rpx;
}

.tab-item {
  position: relative;
  display: flex;
  min-width: 0;
  height: 68rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #60706b;
}

.tab-dot {
  position: absolute;
  top: 12rpx;
  right: 22rpx;
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #e84b4b;
  z-index: 2;
}

.tab-item.active {
  background: #e9f5f0;
  color: #1d6f5f;
}

.tab-icon {
  height: 26rpx;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 26rpx;
}

.tab-text {
  margin-top: 4rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}

.tab-item.publish {
  height: 84rpx;
  transform: translateY(-8rpx);
}

.tab-item.publish .tab-icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #1d6f5f;
  box-shadow: 0 12rpx 28rpx rgba(29, 111, 95, 0.28);
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 500;
  line-height: 70rpx;
  text-align: center;
}

.tab-item.publish .tab-text {
  display: none;
}

.tab-item.publish.active {
  background: transparent;
}

.tab-item.publish.active .tab-icon {
  background: #145346;
}
